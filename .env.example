# --- Genel ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Veritabanı ---
DATABASE_URL=postgresql+asyncpg://msa:msa@localhost:5432/macro_sentiment

# --- Redis (kuyruk + önbellek + dedup) ---
REDIS_URL=redis://localhost:6379/0

# --- Veri kaynakları (Faz 1+) ---
# RSS anahtar gerektirmez. Aşağıdakiler isteğe bağlıdır.
NEWSAPI_KEY=
TWITTER_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
FRED_API_KEY=

# --- LLM (hibrit sentiment, Faz 2) ---
NLP_MODE=finbert            # finbert | llm | hybrid
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-6

# --- Çekme aralıkları (saniye) ---
POLL_INTERVAL_NEWS=60
POLL_INTERVAL_SOCIAL=30
POLL_INTERVAL_FED=1800

# --- Uyarı kanalları (Faz 3) ---
ALERT_MIN_SEVERITY=60
ALERT_WEBHOOK_URL=
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TO